generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Risco {
  id          String   @id @default(uuid())
  titulo      String
  descricao   String
  nivel       String   // baixo | medio | alto | critico
  categoria   String
  status      String   @default("aberto") // aberto | em_tratamento | encerrado
  responsavel String
  prazo       DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Pgr {
  id           String   @id @default(uuid())
  titulo       String
  descricao    String
  status       String   @default("pendente") // pendente | em_andamento | concluido
  responsavel  String
  dataInicio   DateTime?
  dataPrevista DateTime?
  dataConclusao DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Colaborador {
  id         String   @id @default(uuid())
  nome       String
  cargo      String
  setor      String
  email      String   @unique
  telefone   String?
  status     String   @default("ativo") // ativo | inativo | ferias | afastado
  admissao   DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Compliance {
  id          String   @id @default(uuid())
  titulo      String
  descricao   String
  tipo        String   // norma | auditoria | treinamento | incidente
  status      String   @default("pendente") // pendente | em_andamento | concluido | vencido
  responsavel String
  prazo       DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
